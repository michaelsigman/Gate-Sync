# --- Safety ---
# DRY_RUN defaults to true. Set to exactly "false" to actually write to gates.
DRY_RUN=true

# --- Proptia (gate 1: 4 properties, HTML portal) ---
PROPTIA_USERNAME=
PROPTIA_PASSWORD=
PROPTIA_LOGIN_PATH=/en-us/login/

# --- GoAccessControl (gate 2: 1 property, REST API) ---
GOACCESS_USERNAME=
GOACCESS_PASSWORD=
# Supabase publishable anon key (the `apikey` header on the login request).
# Safe to ship; grants nothing on its own. Capture from the login HAR if needed.
GOACCESS_ANON_KEY=

# --- Hostfully ---
HOSTFULLY_API_KEY=
HOSTFULLY_AGENCY_UID=

# --- Server ---
PORT=3000
CRON_SCHEDULE=0 16 * * *
RUN_TOKEN=

# --- Mapping helper (one-time) ---
GOACCESS_RESIDENT_ID=0fac128a-2849-460f-8deb-8c41df7bf559
GOACCESS_VISITOR_TYPE_ID=cd2ad43d-2abd-46fe-aee7-6a23069ac2ff
